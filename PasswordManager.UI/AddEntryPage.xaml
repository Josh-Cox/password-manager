<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PasswordManager.UI.AddEntryPage"
    BackgroundColor="#0F172A"
    Title="Add Entry">

    <ScrollView>

        <VerticalStackLayout
            Padding="24"
            Spacing="22"
            MaximumWidthRequest="700">

            <VerticalStackLayout Spacing="6">

                <Label
                    Text="New Password"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Label
                    Text="Save a new password entry"
                    FontSize="15"
                    TextColor="#94A3B8"/>

            </VerticalStackLayout>

            <VerticalStackLayout Spacing="16">

                <Border
                    BackgroundColor="#121212"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Padding="18,10">

                    <Entry
                        x:Name="SiteEntry"
                        Placeholder="Name / Site"
                        PlaceholderColor="#64748B"
                        TextColor="White"
                        BackgroundColor="Transparent"/>

                </Border>

                <Border
                    BackgroundColor="#121212"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Padding="18,10">

                    <Entry
                        x:Name="UsernameEntry"
                        Placeholder="Username / Email"
                        PlaceholderColor="#64748B"
                        TextColor="White"
                        BackgroundColor="Transparent"/>

                </Border>

                <Border
                    BackgroundColor="#121212"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18"
                    Padding="18,10">

                    <Grid ColumnDefinitions="*,Auto">

                        <Entry
                            x:Name="PasswordEntry"
                            Placeholder="Password"
                            IsPassword="True"
                            PlaceholderColor="#64748B"
                            TextColor="White"
                            BackgroundColor="Transparent"/>

                        <Button
                            Grid.Column="1"
                            Text="Show"
                            BackgroundColor="Transparent"
                            TextColor="#22C55E"
                            Clicked="OnTogglePasswordClicked"/>

                    </Grid>

                </Border>

                <Button
                    Text="Generate Password"
                    HeightRequest="54"
                    CornerRadius="18"
                    BackgroundColor="#2A2A2A"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnGenerateClicked"/>

                <Button
                    Text="Save Entry"
                    HeightRequest="58"
                    CornerRadius="18"
                    BackgroundColor="#22C55E"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"/>

				<Button
                    Text="Cancel"
                    HeightRequest="54"
                    CornerRadius="18"
                    BackgroundColor="#334155"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnCancelClicked"/>

                <Label
                    x:Name="StatusLabel"
                    TextColor="#F87171"
                    HorizontalOptions="Center"/>

            </VerticalStackLayout>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>
    