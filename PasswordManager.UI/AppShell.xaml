<Shell
    x:Class="PasswordManager.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PasswordManager.UI"
    Title="PasswordManager"
    BackgroundColor="#231F20"
    Shell.BackgroundColor="#231F20">

    <ShellContent
        Route="Loading"
        ContentTemplate="{DataTemplate local:LoadingPage}" />

    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate local:LoginPage}" />

    <ShellContent
        Route="UnlockPage"
        ContentTemplate="{DataTemplate local:UnlockPage}" />

    <ShellContent
        Route="VaultPage"
        ContentTemplate="{DataTemplate local:VaultPage}" />

</Shell>