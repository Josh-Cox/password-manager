<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PasswordManager.UI.VaultPage"
    BackgroundColor="{StaticResource BackgroundColor}"
    Shell.NavBarIsVisible="False">

    <Grid Padding="24">

        <!-- Logout -->
        <Button
            Text="Logout"
            HeightRequest="46"
            WidthRequest="100"
            HorizontalOptions="End"
            VerticalOptions="Start"
            Style="{StaticResource LogoutButtonStyle}"
            Clicked="OnLogoutClicked" />

        <VerticalStackLayout
            Padding="5,70,5,0"
            Spacing="18">

            <!-- Header -->
            <VerticalStackLayout Spacing="2">

                <Label
                    Text="Vault"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="{StaticResource PrimaryTextColor}" />

                <Label
                    x:Name="DebugLabel"
                    Text="0 entries"
                    FontSize="14"
                    TextColor="{StaticResource SecondaryTextColor}" />

            </VerticalStackLayout>

            <!-- Search -->
            <Border
                BackgroundColor="{StaticResource SurfaceColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14"
                Padding="10,2">

                <SearchBar
                    x:Name="SearchBar"
                    Placeholder="Search passwords..."
                    TextColor="{StaticResource PrimaryTextColor}"
                    BackgroundColor="Transparent"
                    TextChanged="OnSearchChanged" />

            </Border>

            <!-- Entries -->
            <CollectionView
                x:Name="EntriesList"
                SelectionMode="None">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Content row -->
                            <Grid
            Padding="0,14"
            ColumnDefinitions="*,Auto,Auto"
            VerticalOptions="Center">

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                    CommandParameter="{Binding .}"
                    Tapped="OnEntryTapped"/>
                                </Grid.GestureRecognizers>

                                <VerticalStackLayout Grid.Column="0" Spacing="2">

                                    <Label
                    Text="{Binding Site}"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="{StaticResource PrimaryTextColor}" />

                                    <Label
                    Text="{Binding Username}"
                    FontSize="13"
                    TextColor="{StaticResource SecondaryTextColor}" />

                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="5">

                                    <ImageButton
                                        Padding="8"
                    Source="icn_edit.svg"
                    WidthRequest="35"
                    HeightRequest="35"
                    Opacity="0.9"
                    Clicked="OnEditEntryClicked"
                    CommandParameter="{Binding .}" />

                                    <ImageButton
                    Source="icn_remove.svg"
                                        Padding="8"
                    WidthRequest="35"
                    HeightRequest="35"
                    Opacity="0.85"
                    Clicked="OnDeleteButtonClicked"
                    CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>

                            </Grid>

                            <!-- Divider with symmetric spacing -->
                            <BoxView
            Grid.Row="1"
            HeightRequest="1"
            BackgroundColor="{StaticResource DividerColor}"
            Margin="0,10" />

                        </Grid>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

                <!-- Empty state -->
                <CollectionView.EmptyView>

                    <VerticalStackLayout
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Spacing="12"
                        Margin="0,120,0,0">

                        <Label
                            Text="No passwords yet"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="{StaticResource PrimaryTextColor}" />

                        <Label
                            Text="Tap + to add your first password"
                            FontSize="15"
                            TextColor="{StaticResource SecondaryTextColor}" />

                    </VerticalStackLayout>

                </CollectionView.EmptyView>

            </CollectionView>

        </VerticalStackLayout>

        <!-- FAB -->
        <Button
            Text="+"
            FontSize="30"
            FontAttributes="Bold"
            WidthRequest="68"
            HeightRequest="68"
            Style="{StaticResource FloatingActionButtonStyle}"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="24"
            Clicked="OnAddEntryClicked">

            <Button.Shadow>
                <Shadow Brush="Black" Opacity="0.35" Radius="18" />
            </Button.Shadow>

        </Button>

    </Grid>

</ContentPage>