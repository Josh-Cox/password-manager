<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PasswordManager.UI.VaultPage"
    BackgroundColor="{StaticResource BackgroundColor}"
    Shell.NavBarIsVisible="False">

    <Grid>

        <VerticalStackLayout
            Padding="28,70,28,0"
            Spacing="18">

            <!-- Header -->

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Spacing="2">

                    <Label
                        Text="Vault"
                        FontSize="34"
                        FontAttributes="Bold"
                        TextColor="{StaticResource PrimaryTextColor}" />

                    <Label
                        x:Name="DebugLabel"
                        Text="0 entries"
                        FontSize="14"
                        TextColor="{StaticResource SecondaryTextColor}" />

                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="Logout"
                    HeightRequest="40"
                    Padding="16,0"
                    Style="{StaticResource LogoutButtonStyle}" 
                    Clicked="OnLogoutClicked"
                    />

            </Grid>

            <!-- Search -->

            <Border
                BackgroundColor="{StaticResource SurfaceColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 14"
                Padding="10,2">

                <SearchBar
                    x:Name="SearchBar"
                    Placeholder="Search passwords..."
                    PlaceholderColor="{StaticResource SecondaryTextColor}"
                    TextColor="{StaticResource PrimaryTextColor}"
                    BackgroundColor="Transparent"
                    CancelButtonColor="{StaticResource AccentColor}"
                    TextChanged="OnSearchChanged" />

            </Border>

            <!-- Entries -->

            <CollectionView
                x:Name="EntriesList"
                SelectionMode="Single"
                SelectionChanged="OnEntrySelected">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <!-- Row container -->
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1"/>
                            </Grid.RowDefinitions>

                            <!-- Content Row -->
                            <Grid
                                Padding="0,18"
                                ColumnDefinitions="*,Auto,Auto"
                                VerticalOptions="Center">

                                <!-- Text -->
                                <VerticalStackLayout
                                    Grid.Column="0"
                                    Spacing="4"
                                    VerticalOptions="Center">

                                    <Label
                                        Text="{Binding Site}"
                                        FontSize="22"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource PrimaryTextColor}" />

                                    <Label
                                        Text="{Binding Username}"
                                        FontSize="13"
                                        TextColor="{StaticResource SecondaryTextColor}" />

                                </VerticalStackLayout>

                                <!-- Edit -->
                                <ImageButton
                                    Grid.Column="1"
                                    Source="icn_edit.svg"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Opacity="0.9"
                                    Clicked="OnEditEntryClicked">
                                </ImageButton>

                                <!-- Delete -->
                                <ImageButton
                                    Grid.Column="2"
                                    Source="icn_remove.svg"
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    Opacity="0.85"
                                    Clicked="OnDeleteButtonClicked">
                                </ImageButton>
                            </Grid>

                            <!-- Divider -->
                            <BoxView
                                Grid.Row="1"
                                HeightRequest="1"
                                BackgroundColor="{StaticResource DividerColor}"
                                HorizontalOptions="Fill" />

                        </Grid>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

                <!-- Empty -->

                <CollectionView.EmptyView>

                    <VerticalStackLayout
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Spacing="12"
                        Margin="0,120,0,0">

                        <Label
                            Text="No passwords yet"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="{StaticResource PrimaryTextColor}"
                            HorizontalOptions="Center" />

                        <Label
                            Text="Tap + to add your first password"
                            FontSize="15"
                            TextColor="{StaticResource SecondaryTextColor}"
                            HorizontalOptions="Center" />

                    </VerticalStackLayout>

                </CollectionView.EmptyView>

            </CollectionView>

        </VerticalStackLayout>

        <!-- Floating Add Button -->

        <Button
            x:Name="AddButton"
            Text="+"
            FontSize="30"
            FontAttributes="Bold"
            WidthRequest="68"
            HeightRequest="68"
            Style="{StaticResource FloatingActionButtonStyle}"
            HorizontalOptions="End"
            VerticalOptions="End"
            Margin="24"
            Clicked="OnAddEntryClicked">

            <Button.Shadow>
                <Shadow
                    Brush="Black"
                    Opacity="0.35"
                    Radius="18" />
            </Button.Shadow>

        </Button>

    </Grid>

</ContentPage>