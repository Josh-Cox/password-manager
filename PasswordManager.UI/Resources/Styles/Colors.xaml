<?xml version="1.0" encoding="UTF-8" ?>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Backgrounds -->

    <Color x:Key="BackgroundColor">
        #121212
    </Color>

    <Color x:Key="SurfaceColor">
        #1E1E1E
    </Color>

    <Color x:Key="DividerColor">
        #2A2A2A
    </Color>

    <!-- Text -->

    <Color x:Key="PrimaryTextColor">
        #FFFFFF
    </Color>

    <Color x:Key="SecondaryTextColor">
        #A1A1AA
    </Color>

    <!-- Accent -->

    <Color x:Key="AccentColor">
        #7DD3FC
    </Color>

    <Color x:Key="AccentColorDark">
        #38BDF8
    </Color>

    <!-- Danger -->

    <Color x:Key="DangerColor">
        #F87171
    </Color>

</ResourceDictionary>